# PostgreSQL (used by docker-compose)
POSTGRES_USER=healthguard
POSTGRES_PASSWORD=healthguard
POSTGRES_DB=healthguard
DATABASE_URL=postgresql+psycopg2://healthguard:healthguard@postgres:5432/healthguard

# Redis (used by docker-compose)
REDIS_URL=redis://redis:6379/0

# OpenAI (optional, used by agent)
OPENAI_API_KEY=
